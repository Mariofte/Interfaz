{
  // ╔══════════════════════════════════════════════════════╗
  // ║  settings.json — Configuración del editor           ║
  // ║  Carpeta: .vscode/settings.json                     ║
  // ╚══════════════════════════════════════════════════════╝
  // ── Python ───────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  // En Mac/Linux usa:
  // "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  // ── Linting (detectar errores sin correr) ────────────────
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false, // pylint es muy estricto
  "python.linting.flake8Enabled": true, // flake8 es más amigable
  "python.linting.flake8Args": [
    "--max-line-length=100", // líneas hasta 100 chars
    "--ignore=E302,E303,W291,W293" // ignora espacios en blanco
  ],
  // ── Formato automático ────────────────────────────────────
  "editor.formatOnSave": true, // formatea al guardar
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit" // ordena imports al guardar
    }
  },
  // ── IntelliSense (autocompletado) ─────────────────────────
  "python.analysis.typeCheckingMode": "basic", // detecta errores de tipos
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true, // completa paréntesis
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.quickSuggestions": {
    "strings": true // sugerencias dentro de strings
  },
  // ── Editor visual ─────────────────────────────────────────
  "editor.fontSize": 14,
  "editor.fontFamily": "Fira Code, Cascadia Code, Consolas, monospace",
  "editor.fontLigatures": true, // flechas => bonitas
  "editor.lineHeight": 1.6,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [
    100
  ], // línea guía a los 100 chars
  "editor.renderWhitespace": "boundary", // muestra espacios extra
  "editor.minimap.enabled": true,
  "editor.bracketPairColorization.enabled": true, // colores en paréntesis
  "editor.guides.bracketPairs": true,
  // ── Terminal integrada ────────────────────────────────────
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  // En Mac/Linux:
  // "terminal.integrated.defaultProfile.linux": "bash",
  // ── Explorador de archivos ────────────────────────────────
  "explorer.compactFolders": false, // no colapsa carpetas vacías
  "files.exclude": {
    "**/__pycache__": true, // oculta __pycache__
    "**/*.pyc": true, // oculta .pyc
    "**/.venv": false, // muestra el venv
    "**/.pytest_cache": true
  },
  // ── Guardado automático ───────────────────────────────────
  "files.autoSave": "onFocusChange", // guarda al cambiar de archivo
  // ── Git ───────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false
}